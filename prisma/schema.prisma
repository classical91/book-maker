generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BookProject {
  id            String        @id @default(cuid())
  ownerId       String        @map("owner_id")
  title         String
  genre         String
  audience      String
  tone          String
  premise       String        @db.Text
  targetWords   Int           @map("target_words")
  totalChapters Int           @map("total_chapters")
  summary       String?       @db.Text
  status        ProjectStatus @default(DRAFT)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  chapters      Chapter[]
  memory        BookMemory?

  @@index([ownerId, updatedAt])
  @@map("book_projects")
}

model Chapter {
  id             String        @id @default(cuid())
  projectId      String        @map("project_id")
  chapterNumber  Int           @map("chapter_number")
  title          String
  outlineBullets Json          @map("outline_bullets")
  brief          Json?
  content        String?       @db.Text
  summary        String?       @db.Text
  wordCount      Int?          @map("word_count")
  status         ChapterStatus @default(OUTLINED)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  project        BookProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, chapterNumber])
  @@index([projectId, status])
  @@map("chapters")
}

model BookMemory {
  id              String      @id @default(cuid())
  projectId       String      @unique @map("project_id")
  keyTerms        Json?       @map("key_terms")
  styleRules      Json?       @map("style_rules")
  continuityNotes String?     @db.Text @map("continuity_notes")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  project         BookProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("book_memory")
}

enum ProjectStatus {
  DRAFT
  OUTLINE_READY
  WRITING
  COMPLETE

  @@map("project_status")
}

enum ChapterStatus {
  OUTLINED
  BRIEF_READY
  DRAFTED
  REVIEWED
  COMPLETE

  @@map("chapter_status")
}

model Ebook {
  id        String         @id @default(cuid())
  ownerId   String         @map("owner_id")
  title     String
  content   String?        @db.Text
  chapters  EbookChapter[]
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@index([ownerId, updatedAt])
  @@map("ebooks")
}

model EbookChapter {
  id        String   @id @default(cuid())
  ebookId   String   @map("ebook_id")
  title     String   @default("Untitled Chapter")
  content   String?  @db.Text
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ebook     Ebook    @relation(fields: [ebookId], references: [id], onDelete: Cascade)

  @@index([ebookId, position])
  @@map("ebook_chapters")
}
