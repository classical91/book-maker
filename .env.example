DATABASE_URL="postgresql://postgres:postgres@localhost:5432/book_maker?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/book_maker?schema=public"
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-5.1"
# Optional per-operation model overrides (each falls back to OPENAI_MODEL).
# OPENAI_OUTLINE_MODEL="gpt-5.1"
# OPENAI_BRIEF_MODEL="gpt-5.1"
# OPENAI_DRAFT_MODEL="gpt-5.1"

# Authentication mode: "single_user" or "multi_user".
# - single_user: every request is attributed to SINGLE_USER_ID (no sign-in).
# - multi_user:  requests are authenticated with Clerk (keys required below).
# If unset, the mode is inferred (multi_user when Clerk keys are present,
# single_user in development). In production, an unset mode with no Clerk keys
# is a hard configuration error so the app fails closed instead of silently
# sharing one account.
APP_MODE="single_user"
SINGLE_USER_ID="jason"

# Required only for multi_user mode.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
